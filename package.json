{
  "name": "storagebus",
  "version": "0.9.0",
  "description": "Storage abstraction library for Node.js",
  "license": "MIT",
  "author": "Ducktors <your@ducktors.dev> (https://ducktors.dev)",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "turbo build",
    "commit": "npx git-cz",
    "commitlint": "commitlint",
    "dev": "turbo dev",
    "format": "turbo format",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "precommit": "pnpm install",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky || true",
    "release": "pnpm build && changeset publish",
    "test": "turbo test",
    "test:ci": "turbo test:ci"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "uuid": "11.1.1",
      "form-data@<2.5.6": ">=2.5.6",
      "js-yaml@<3.15.0": ">=3.15.0 <4"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ducktors/storagebus.git"
  },
  "keywords": [],
  "devDependencies": {
    "@biomejs/biome": "catalog:devDeps",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/lint": "^21.0.2",
    "@commitlint/prompt": "^21.0.2",
    "commitlint-plugin-function-rules": "^5.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "turbo": "^2.9.16"
  },
  "engines": {
    "node": ">=24.12.0 <25 || >=26.0.0 <27"
  },
  "bugs": {
    "url": "https://github.com/ducktors/storagebus/issues"
  },
  "homepage": "https://github.com/ducktors/storagebus#readme"
}
