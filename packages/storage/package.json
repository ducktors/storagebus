{
  "name": "@storagebus/storage",
  "version": "0.10.4",
  "description": "",
  "license": "MIT",
  "author": "Ducktors <your@ducktors.dev> (https://ducktors.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ducktors/storagebus",
    "directory": "packages/storage"
  },
  "private": false,
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/storage.d.ts",
      "typescript": "./src/storage.ts",
      "import": "./dist/storage.js",
      "require": "./dist/storage.js"
    },
    "./file": {
      "types": "./dist/file.d.ts",
      "typescript": "./src/file.ts",
      "import": "./dist/file.js",
      "require": "./dist/file.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "typescript": "./src/errors.ts",
      "import": "./dist/errors.js",
      "require": "./dist/errors.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "typescript": "./src/memory.ts",
      "import": "./dist/memory.js",
      "require": "./dist/memory.js"
    },
    "./driver": {
      "types": "./dist/memory.d.ts",
      "typescript": "./src/memory.ts",
      "import": "./dist/memory.js",
      "require": "./dist/memory.js"
    },
    "./compliance-test": {
      "types": "./dist/compliance-test.d.ts",
      "typescript": "./src/compliance-test.ts",
      "import": "./dist/compliance-test.js",
      "require": "./dist/compliance-test.js"
    }
  },
  "main": "dist/storage.js",
  "types": "dist/storage.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc && cp src/latin-chars.json dist/latin-chars.json",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "preinstall": "npx only-allow pnpm",
    "test": "tsx --conditions=typescript --test ./test/*.ts",
    "test:ci": "c8 --all --src src --reporter lcov --reporter text tsx --conditions=typescript --test ./test/*.ts",
    "test:watch": "tsx --conditions=typescript --watch --test ./test/*.ts"
  },
  "keywords": [],
  "dependencies": {
    "tslib": "catalog:prodDeps"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:devDeps",
    "@ducktors/tsconfig": "catalog:devDeps",
    "@types/node": "catalog:devDeps",
    "c8": "catalog:devDeps",
    "rimraf": "catalog:devDeps",
    "tsx": "catalog:devDeps",
    "typescript": "catalog:devDeps"
  }
}
