    "directory": "packages/memory"
  },
  "private": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/memory.d.ts",
      "typescript": "./src/memory.ts",
      "import": "./dist/memory.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "preinstall": "npx only-allow pnpm",
    "test": "node --conditions=typescript --test test/*.ts",
    "test:ci": "c8 --all --src src --reporter lcov --reporter text node --conditions=typescript --test ./test/*.ts",
    "test:watch": "node --watch --conditions=typescript --test ./test/*.ts"
  },
  "keywords": [],
  "peerDependencies": {
    "@storagebus/storage": "workspace:^"
  },
  "dependencies": {
    "tslib": "catalog:prodDeps"
  },
  "devDependencies": {
    "@storagebus/storage": "workspace:*",
    "@biomejs/biome": "catalog:devDeps",
    "@types/node": "catalog:devDeps",
    "c8": "catalog:devDeps",
    "rimraf": "catalog:devDeps",
    "typescript": "catalog:devDeps"
  }
