{
  "name": "@storagebus/s3",
  "version": "0.12.1",
  "description": "",
  "license": "MIT",
  "author": "Ducktors <your@ducktors.dev> (https://ducktors.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ducktors/storagebus",
    "directory": "packages/s3"
  },
  "private": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/adapter.d.ts",
      "typescript": "./src/adapter.ts",
      "import": "./dist/adapter.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "preinstall": "npx only-allow pnpm",
    "test": "node --conditions=typescript --test test/*.ts",
    "test:ci": "c8 --all --src src --reporter lcov --reporter text node --conditions=typescript --test ./test/*.ts",
    "test:watch": "node --watch --conditions=typescript --test ./test/*.ts"
  },
  "keywords": [],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1064.0",
    "@aws-sdk/lib-storage": "^3.1064.0",
    "tslib": "catalog:prodDeps"
  },
  "peerDependencies": {
    "@storagebus/storage": "workspace:^"
  },
  "devDependencies": {
    "@storagebus/storage": "workspace:*",
    "@biomejs/biome": "catalog:devDeps",
    "@types/mime-types": "catalog:devDeps",
    "@types/node": "catalog:devDeps",
    "c8": "catalog:devDeps",
    "rimraf": "catalog:devDeps",
    "typescript": "catalog:devDeps"
  }
}
