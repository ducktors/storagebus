{
  "name": "@storagebus/local",
  "version": "0.12.4",
  "description": "",
  "license": "MIT",
  "author": "Ducktors <your@ducktors.dev> (https://ducktors.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ducktors/storagebus",
    "directory": "packages/local"
  },
  "private": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/local.d.ts",
      "typescript": "./src/local.ts",
      "import": "./dist/local.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "preinstall": "npx only-allow pnpm",
    "test": "node --conditions=typescript --test test/*.ts",
    "test:ci": "mkdir -p coverage && node --conditions=typescript --test --experimental-test-coverage '--test-coverage-include=src/**/*.ts' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info ./test/*.ts",
    "test:watch": "node --watch --conditions=typescript --test ./test/*.ts"
  },
  "keywords": [],
  "peerDependencies": {
    "@storagebus/storage": "workspace:^"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:devDeps",
    "@storagebus/storage": "workspace:*",
    "@types/node": "catalog:devDeps",
    "mitata": "^1.0.34",
    "rimraf": "catalog:devDeps",
    "typescript": "catalog:devDeps"
  }
}
